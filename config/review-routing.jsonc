// Review routing rules (v1.1.0 US-005)
//
// Schema: { schemaVersion: 1, approvalReviewers: [...], reviewResultContract: {...},
//           alwaysInclude: [...], rules: [{pathMatch, reviewers}],
//           securityPatterns: [regex strings], fallback: [full reviewer set] }
//
// Rules are evaluated top-to-bottom. The union of all matching rules' `reviewers`
// is returned. If any file content matches `securityPatterns`, security-reviewer
// is always added. If no rule matches, fallback is used with a warning.
//
// Disable entirely via .ao/autonomy.json -> { "reviewRouter": { "disabled": true } }.
{
  "schemaVersion": 1,

  // Only these non-implementation agents may participate in an approval gate.
  // Themis can run checks but cannot edit directly; the exact-tree freshness
  // gate rejects command side effects. The router also enforces this list in
  // code, so stale rules cannot re-introduce implementation roles.
  "approvalReviewers": [
    "aphrodite",
    "architect",
    "code-reviewer",
    "security-reviewer",
    "themis"
  ],

  // Versioned output contract supplied to every routed reviewer by Atlas/Athena.
  // AO_REVIEW_V1 is exact JSON (no Markdown fence or surrounding prose).
  "reviewResultContract": {
    "name": "AO_REVIEW_V1",
    "schemaVersion": 1,
    "verdicts": ["APPROVE", "REVISE", "REJECT", "BLOCKED"],
    "required": ["schemaVersion", "reviewer", "reviewDigest", "verdict", "findings", "escalations"],
    "findingRequired": ["severity", "confidence", "file", "line", "evidence", "recommendation"],
    "escalationRequired": ["additionalReviewer", "reason"]
  },

  // Reviewers always included regardless of diff scope.
  // Set to ["*"] to force the full fallback reviewer set on every diff (rollback path).
  "alwaysInclude": [],

  // Diff-scope rules. Each rule: { name, pathMatch (regex), reviewers }.
  // pathMatch is evaluated against each diff path.
  "rules": [
    {
      "name": "frontend-styles",
      "pathMatch": "\\.(css|scss|sass|less)$",
      "reviewers": ["aphrodite"]
    },
    {
      "name": "frontend",
      "pathMatch": "\\.(tsx|jsx|vue|svelte|html|htm)$|^(components|pages)/",
      "reviewers": ["aphrodite", "code-reviewer"]
    },
    {
      "name": "backend",
      "pathMatch": "\\.(go|rs|py|rb|java|kt|scala|ex|exs|cs|php)$|^(api|server|backend|services|lib|pkg|cmd|internal)/",
      "reviewers": ["code-reviewer", "architect", "security-reviewer"]
    },
    {
      "name": "node-backend",
      "pathMatch": "^(api|server|backend|services|routes|controllers|middleware)/.*\\.(ts|js|mjs|cjs)$",
      "reviewers": ["code-reviewer", "architect", "security-reviewer"]
    },
    {
      "name": "orchestration-runtime",
      "pathMatch": "^(scripts|hooks|evals)/.*\\.(ts|js|mjs|cjs)$",
      "reviewers": ["code-reviewer", "security-reviewer"]
    },
    {
      "name": "generic-js-ts",
      "pathMatch": "\\.(ts|js|mjs|cjs)$",
      "reviewers": ["code-reviewer"]
    },
    {
      "name": "infra",
      "pathMatch": "\\.(tf|tfvars|yaml|yml)$|^(terraform|infra|k8s|kubernetes|helm|ansible|.github/workflows)/|Dockerfile|docker-compose",
      "reviewers": ["architect", "security-reviewer", "code-reviewer"]
    },
    {
      "name": "auth",
      "pathMatch": "(auth|login|signin|signup|session|oauth|oidc|jwt|saml|passwd|password|crypto|token)",
      "reviewers": ["security-reviewer", "code-reviewer", "architect"]
    },
    {
      "name": "tests",
      "pathMatch": "(test|spec|__tests__|__mocks__)/|\\.(test|spec)\\.(ts|js|mjs|tsx|jsx|go|py|rb)$",
      "reviewers": ["themis", "code-reviewer"]
    },
    {
      "name": "docs",
      "pathMatch": "\\.(md|mdx|rst|txt)$|^(docs|documentation)/",
      "reviewers": ["code-reviewer"]
    }
  ],

  // Regex patterns (case-insensitive) — if ANY diff content matches, security-reviewer
  // is force-included. Stored as strings, compiled to RegExp at router time.
  "securityPatterns": [
    "token",
    "secret",
    "apikey",
    "api[_-]?key",
    "credential",
    "hmac",
    "signature",
    "sign(ed|ing)?",
    "bcrypt",
    "argon2?",
    "scrypt",
    "pbkdf2?",
    "private[_-]?key",
    "privatekey",
    "(?<![a-z])rsa(?![a-z])",
    "ecdsa",
    "ed25519",
    "csrf",
    "xsrf",
    "saml",
    "oidc",
    "jwks",
    "(?<![a-z])kms(?![a-z])",
    "vault",
    "(?<![a-z])jwt",
    "session[_-]?id",
    "password",
    "oauth",
    "cookie",
    "refresh.?token",
    "Authorization",
    "bearer",
    "client[_-]?secret",
    "access[_-]?key",
    "secret[_-]?access[_-]?key",
    "ssh[_-]?key",
    "OPENSSH PRIVATE KEY",
    "BEGIN RSA PRIVATE KEY",
    "BEGIN EC PRIVATE KEY",
    "BEGIN PRIVATE KEY",
    "ssh-(rsa|ed25519|dss|ecdsa)",
    "connection.?string",
    "database.?url",
    "db[_-]?url",
    "\\.pem(?![a-z])",
    "\\.p12(?![a-z])",
    "\\.keystore",
    "\\.env(\\.|\\b)",
    "crypto\\.subtle",
    "jwt[-_]?decode",
    "signed[-_]?url"
  ],

  // Full fallback reviewer set when no rule matches.
  "fallback": [
    "code-reviewer",
    "architect",
    "security-reviewer",
    "aphrodite",
    "themis"
  ]
}
