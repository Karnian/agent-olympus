{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-olympus.local/evals/baseline.schema.json",
  "title": "Agent Olympus Regression Eval Baseline",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "track",
    "k",
    "tasks"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "track": {
      "const": "regression"
    },
    "k": {
      "type": "integer",
      "minimum": 1
    },
    "tasks": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "k",
          "passHatK",
          "source",
          "runId",
          "measuredAt",
          "modelTier",
          "orchestrator",
          "benchmarkFingerprint",
          "pipelineProtocolFingerprint"
        ],
        "properties": {
          "k": {
            "type": "integer",
            "minimum": 1
          },
          "passHatK": {
            "const": true
          },
          "source": {
            "enum": [
              "declared-target",
              "live"
            ]
          },
          "runId": {
            "type": [
              "string",
              "null"
            ]
          },
          "measuredAt": {
            "type": [
              "string",
              "null"
            ]
          },
          "modelTier": {
            "type": [
              "string",
              "null"
            ]
          },
          "orchestrator": {
            "enum": [
              "atlas",
              "athena",
              "solo"
            ]
          },
          "benchmarkFingerprint": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "pipelineProtocolFingerprint": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    }
  }
}
