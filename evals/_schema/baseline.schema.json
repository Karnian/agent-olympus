{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-olympus.local/evals/baseline.schema.json",
  "title": "Agent Olympus Regression Eval Baseline",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "track",
    "k",
    "tasks"
  ],
  "properties": {
    "schemaVersion": {
      "const": 2
    },
    "track": {
      "const": "regression"
    },
    "k": {
      "type": "integer",
      "minimum": 1
    },
    "tasks": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "k",
          "passHatK",
          "source",
          "runId",
          "measuredAt",
          "modelTier",
          "orchestrator",
          "benchmarkFingerprint",
          "pipelineProtocolFingerprint",
          "claudeCliVersion",
          "pluginFingerprint",
          "targetPromptFingerprint",
          "observedModels",
          "maxBudgetUsd",
          "providerRuntime"
        ],
        "properties": {
          "k": {
            "type": "integer",
            "minimum": 1
          },
          "passHatK": {
            "const": true
          },
          "source": {
            "enum": [
              "declared-target",
              "live"
            ]
          },
          "runId": {
            "type": [
              "string",
              "null"
            ]
          },
          "measuredAt": {
            "type": [
              "string",
              "null"
            ]
          },
          "modelTier": {
            "type": [
              "string",
              "null"
            ]
          },
          "orchestrator": {
            "enum": [
              "atlas",
              "athena",
              "solo"
            ]
          },
          "benchmarkFingerprint": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "pipelineProtocolFingerprint": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "claudeCliVersion": {
            "type": [
              "string",
              "null"
            ]
          },
          "pluginFingerprint": {
            "type": [
              "string",
              "null"
            ],
            "pattern": "^[a-f0-9]{64}$"
          },
          "targetPromptFingerprint": {
            "type": [
              "string",
              "null"
            ],
            "pattern": "^[a-f0-9]{64}$"
          },
          "observedModels": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "type": "string",
              "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]*$"
            },
            "minItems": 1,
            "maxItems": 16,
            "uniqueItems": true
          },
          "maxBudgetUsd": {
            "type": [
              "number",
              "null"
            ],
            "exclusiveMinimum": 0,
            "maximum": 100
          },
          "providerRuntime": {
            "type": [
              "object",
              "null"
            ],
            "additionalProperties": false,
            "required": [
              "effort",
              "efforts",
              "fastModeStates",
              "usageSpeeds",
              "serviceTiers"
            ],
            "properties": {
              "effort": {
                "type": "string",
                "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]{0,63}$"
              },
              "efforts": {
                "$ref": "#/$defs/runtimeValues"
              },
              "fastModeStates": {
                "$ref": "#/$defs/runtimeValues"
              },
              "usageSpeeds": {
                "$ref": "#/$defs/runtimeValues"
              },
              "serviceTiers": {
                "$ref": "#/$defs/runtimeValues"
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "runtimeValues": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]{0,63}$"
      },
      "minItems": 1,
      "maxItems": 16,
      "uniqueItems": true
    }
  }
}
