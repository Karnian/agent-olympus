{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-olympus.local/evals/task.schema.json",
  "title": "Agent Olympus Eval Task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "track",
    "orchestrator",
    "prompt",
    "difficulty",
    "timeoutMs",
    "modelTier",
    "k"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "track": {
      "enum": [
        "regression",
        "capability"
      ]
    },
    "orchestrator": {
      "enum": [
        "atlas",
        "athena",
        "solo",
        "agent"
      ]
    },
    "agent": {
      "type": "string",
      "enum": [
        "atlas",
        "athena",
        "metis",
        "prometheus",
        "momus",
        "hermes",
        "executor",
        "designer",
        "aphrodite",
        "test-engineer",
        "debugger",
        "architect",
        "security-reviewer",
        "code-reviewer",
        "explore",
        "writer",
        "hephaestus",
        "ask",
        "themis"
      ]
    },
    "prompt": {
      "type": "string",
      "minLength": 1
    },
    "difficulty": {
      "type": "string"
    },
    "timeoutMs": {
      "type": "integer",
      "minimum": 1
    },
    "modelTier": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]*$"
    },
    "k": {
      "type": "integer",
      "minimum": 1
    },
    "maxBudgetUsd": {
      "type": "number",
      "exclusiveMinimum": 0,
      "maximum": 100
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "orchestrator": {
            "const": "agent"
          }
        },
        "required": [
          "orchestrator"
        ]
      },
      "then": {
        "properties": {
          "track": {
            "const": "capability"
          }
        },
        "required": [
          "agent",
          "maxBudgetUsd"
        ]
      },
      "else": {
        "not": {
          "required": [
            "agent"
          ]
        }
      }
    }
  ]
}
